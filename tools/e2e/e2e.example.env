# Legacy env-file config (gitignored). Preferred config file is `tools/e2e/e2e.local.json`.
# Copy to `tools/e2e/e2e.local.env` and fill in values.
#
# Minimal required settings for `python3 tools/e2e/test_rs485_stub.py`
#
# Fill these in for your environment.

MQTT_HOST=your-broker-host-or-ip
MQTT_PORT=1883
MQTT_USER=your-mqtt-username
# Prefer MQTT_PASSFILE over MQTT_PASS so secrets don't end up in shell history.
MQTT_PASSFILE=/path/to/mqtt_pass.txt

# Optional: pin to a specific device topic root; otherwise the script will auto-discover.
# DEVICE_TOPIC=Alpha2MQTT-0F8626

# Required when flashing is needed (smart-flash mismatch or `--force-flash`).
# DEVICE_HTTP_BASE=http://device-ip
