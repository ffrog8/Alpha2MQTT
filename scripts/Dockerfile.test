FROM ubuntu:22.04

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        cmake \
        g++ \
        make \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /repo

# Copy the repo into the image so tests can run even when the Docker daemon
# cannot access local bind mounts (e.g., remote Docker socket).
COPY . /repo
